# Purpose: Documents backend environment variables used by Docker and local runs.
NODE_ENV=development
PORT=5000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tourism
POSTGRES_USER=tourism_admin
POSTGRES_PASSWORD=tourism_password
MONGO_URI=mongodb://localhost:27017/tourism_content
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret-before-production
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4.1-mini
